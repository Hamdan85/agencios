#!/usr/bin/env ruby
# frozen_string_literal: true

# ─────────────────────────────────────────────────────────────────────────────
# setup_production_credentials — write production credentials NON-INTERACTIVELY.
#
# "sem logar": no `rails credentials:edit` editor session, no login prompt, and
# no secret values printed to stdout/logs (every value is masked in the summary).
# Runs before a deploy to guarantee config/credentials/production.yml.enc exists
# and is complete.
#
# It is MERGE-ONLY and idempotent. Existing values are NEVER overwritten — this
# is essential: rotating `active_record_encryption.*` would make every encrypted
# token column (SocialAccount/Setting/User) undecryptable, and rotating
# `secret_key_base` would invalidate every session. The script only FILLS GAPS:
#   • generates secret_key_base + active_record_encryption + VAPID if absent
#   • copies vendor secrets from ENV into the canonical structure, when present
#     and not already set (mapping mirrors `credential(:vendor, :key, env:)`)
#
# Usage:
#   bin/setup_production_credentials            # fill missing keys, write if changed
#   FORCE=1 bin/setup_production_credentials     # overwrite even existing values
#
# The matching key is read from ENV["RAILS_MASTER_KEY"] or
# config/credentials/production.key; if neither exists a fresh key is generated
# and written to the key file (which is gitignored — feed it to the platform as
# the RAILS_MASTER_KEY variable). Canonical shape: config/credentials.example.yml
# ─────────────────────────────────────────────────────────────────────────────

require "bundler/setup"
require "active_support"
require "active_support/encrypted_configuration"
require "yaml"
require "securerandom"
require "openssl"
require "base64"
require "pathname"

ROOT        = Pathname.new(File.expand_path("..", __dir__))
CONFIG_PATH = ROOT.join("config/credentials/production.yml.enc")
KEY_PATH    = ROOT.join("config/credentials/production.key")
FORCE       = ENV["FORCE"] == "1"
VAPID_CURVE = "prime256v1"

# ── ENV → credential path map (mirrors the `env:` fallbacks in the app) ───────
ENV_MAP = {
  %w[secret_key_base]             => "SECRET_KEY_BASE",
  %w[meta app_id]                 => "META_APP_ID",
  %w[meta app_secret]             => "META_APP_SECRET",
  %w[meta webhook_verify_token]   => "META_WEBHOOK_VERIFY_TOKEN",
  %w[tiktok client_key]           => "TIKTOK_CLIENT_KEY",
  %w[tiktok client_secret]        => "TIKTOK_CLIENT_SECRET",
  %w[tiktok webhook_secret]       => "TIKTOK_WEBHOOK_SECRET",
  %w[linkedin client_id]          => "LINKEDIN_CLIENT_ID",
  %w[linkedin client_secret]      => "LINKEDIN_CLIENT_SECRET",
  %w[x client_id]                 => "X_CLIENT_ID",
  %w[x client_secret]             => "X_CLIENT_SECRET",
  %w[google client_id]            => "GOOGLE_CLIENT_ID",
  %w[google client_secret]        => "GOOGLE_CLIENT_SECRET",
  %w[anthropic api_key]           => "ANTHROPIC_API_KEY",
  %w[anthropic model]             => "ANTHROPIC_MODEL",
  %w[heygen api_key]              => "HEYGEN_API_KEY",
  %w[heygen webhook_secret]       => "HEYGEN_WEBHOOK_SECRET",
  %w[image_gen api_key]           => "IMAGE_GEN_API_KEY",
  %w[image_gen base_url]          => "IMAGE_GEN_BASE_URL",
  %w[image_gen model_version]     => "IMAGE_GEN_MODEL_VERSION",
  %w[stripe secret_key]           => "STRIPE_SECRET_KEY",
  %w[stripe webhook_secret]       => "STRIPE_WEBHOOK_SECRET",
  %w[stripe prices solo]          => "STRIPE_PRICE_SOLO",
  %w[stripe prices agencia]       => "STRIPE_PRICE_AGENCIA",
  %w[stripe prices enterprise]    => "STRIPE_PRICE_ENTERPRISE",
  %w[stripe prices carousel_generation] => "STRIPE_PRICE_CAROUSEL_GENERATION",
  %w[stripe prices video_generation]    => "STRIPE_PRICE_VIDEO_GENERATION",
  %w[mercado_pago access_token]   => "MERCADO_PAGO_ACCESS_TOKEN",
  %w[mercado_pago client_id]      => "MERCADO_PAGO_CLIENT_ID",
  %w[mercado_pago client_secret]  => "MERCADO_PAGO_CLIENT_SECRET",
  %w[mercado_pago webhook_secret] => "MERCADO_PAGO_WEBHOOK_SECRET"
}.freeze

# ── tiny nested-hash helpers ─────────────────────────────────────────────────
def dig_path(hash, path)
  path.reduce(hash) { |acc, k| acc.is_a?(Hash) ? acc[k] : nil }
end

def present?(value)
  !value.nil? && value.to_s.strip != ""
end

# Set hash[*path] = value only if currently blank (unless FORCE). Returns the
# action taken (:set | :forced | :kept) for the summary.
def fill(hash, path, value)
  return :skip unless present?(value)

  existing = dig_path(hash, path)
  return :kept if present?(existing) && !FORCE

  parent = path[0..-2].reduce(hash) { |acc, k| acc[k] ||= {} }
  parent[path[-1]] = value.to_s
  present?(existing) ? :forced : :set
end

def mask(value)
  s = value.to_s
  return "(blank)" if s.empty?
  return "•••" if s.length <= 8

  "#{s[0, 4]}…#{s[-4, 4]} [#{s.length}]"
end

# ── VAPID P-256 keypair (same encoding the app's WebPush client expects) ──────
def generate_vapid
  ec         = OpenSSL::PKey::EC.generate(VAPID_CURVE)
  priv_bytes = ec.private_key.to_s(2).rjust(32, "\x00")
  pub_bytes  = ec.public_key.to_bn.to_s(2)
  raise "bad VAPID public length"  unless pub_bytes.bytesize == 65
  raise "bad VAPID private length" unless priv_bytes.bytesize == 32

  {
    "public_key"  => Base64.urlsafe_encode64(pub_bytes, padding: false),
    "private_key" => Base64.urlsafe_encode64(priv_bytes, padding: false)
  }
end

# ── resolve the encryption key (generate one if this is a fresh setup) ────────
key = ENV["RAILS_MASTER_KEY"]
key ||= KEY_PATH.read.strip if KEY_PATH.exist?
generated_key = false
if !present?(key)
  key = SecureRandom.hex(16) # 32 hex chars — Rails master key format
  KEY_PATH.dirname.mkpath
  KEY_PATH.write(key)
  KEY_PATH.chmod(0o600)
  generated_key = true
end
ENV["RAILS_MASTER_KEY"] = key # so EncryptedConfiguration picks it up

enc = ActiveSupport::EncryptedConfiguration.new(
  config_path: CONFIG_PATH.to_s,
  key_path: KEY_PATH.to_s,
  env_key: "RAILS_MASTER_KEY",
  raise_if_missing_key: true
)

existed = CONFIG_PATH.exist?
raw     = existed ? enc.read.to_s.dup.force_encoding("UTF-8") : ""
data    = YAML.safe_load(raw, aliases: true) || {}
before  = Marshal.dump(data) # cheap deep snapshot for change detection
actions = []

# 1. Rails core — generated, never rotated once present.
case fill(data, %w[secret_key_base], ENV["SECRET_KEY_BASE"] || SecureRandom.hex(64))
when :set    then actions << ["secret_key_base", "generated"]
when :forced then actions << ["secret_key_base", "OVERWRITTEN (FORCE)"]
end

# 2. Active Record Encryption — generated as a block, never rotated once present
#    (rotating these would orphan every encrypted token column).
are_present = present?(dig_path(data, %w[active_record_encryption primary_key]))
if !are_present || FORCE
  data["active_record_encryption"] = {
    "primary_key"         => SecureRandom.alphanumeric(32),
    "deterministic_key"   => SecureRandom.alphanumeric(32),
    "key_derivation_salt" => SecureRandom.alphanumeric(32)
  }
  actions << ["active_record_encryption", are_present ? "OVERWRITTEN (FORCE)" : "generated"]
end

# 3. VAPID — Web Push keypair, generated if absent.
if !present?(dig_path(data, %w[vapid public_key])) || FORCE
  data["vapid"] = generate_vapid
  actions << ["vapid", "generated"]
end

# 4. Vendor secrets from ENV (merge-only).
ENV_MAP.each do |path, env_key|
  next if path == %w[secret_key_base] # handled above

  case fill(data, path, ENV[env_key])
  when :set    then actions << [path.join("."), "set from #{env_key}"]
  when :forced then actions << [path.join("."), "OVERWRITTEN from #{env_key}"]
  end
end

# ── validate, then write only if something changed ───────────────────────────
abort "FATAL: secret_key_base missing after merge" unless present?(data["secret_key_base"])
YAML.safe_load(YAML.dump(data), aliases: true) # parse round-trip sanity check

changed = Marshal.dump(data) != before || !existed
if changed
  enc.write(YAML.dump(data))
end

# ── summary (masked) ─────────────────────────────────────────────────────────
puts "== production credentials =="
puts "  file:           #{CONFIG_PATH.relative_path_from(ROOT)}#{existed ? '' : '  (created)'}"
puts "  key:            #{generated_key ? "GENERATED → #{KEY_PATH.relative_path_from(ROOT)} (set this as RAILS_MASTER_KEY on the platform)" : 'existing'}"
puts "  secret_key_base #{mask(data['secret_key_base'])}"
puts "  changed:        #{changed ? 'yes (written)' : 'no (already complete)'}"
if actions.any?
  puts "  applied:"
  actions.each { |k, what| puts "    • #{k}: #{what}" }
else
  puts "  applied:        nothing (all present)"
end

# Report which canonical vendor keys are still blank, so gaps are visible
# without revealing anything sensitive.
missing = ENV_MAP.keys.reject { |path| present?(dig_path(data, path)) }
unless missing.empty?
  puts "  still blank (integrations will degrade gracefully until set):"
  missing.each_slice(3) { |group| puts "    #{group.map { |p| p.join('.') }.join(', ')}" }
end
