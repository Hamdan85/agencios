<% content_for :preheader do %><%= t('mailers.subtask.assigned.preheader', title: @subtask.title) %><% end %>
<% content_for :eyebrow do %><%= t('mailers.subtask.assigned.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.subtask.assigned.heading') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %>, <%= @assignee.display_name %>.
  <% if @actor_name %><%= t('mailers.subtask.assigned.assigned_by_html', name: @actor_name) %><% else %><%= t('mailers.subtask.assigned.assigned_generic') %><% end %>
  <%= t('mailers.subtask.assigned.body_suffix_html', title: @ticket.display_title) %>
</p>

<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin:8px 0 20px;background-color:#F5F4FB;border-radius:14px;">
  <tr><td style="padding:18px 20px;">
    <p style="margin:0;font-size:16px;font-weight:700;color:#18122B;">✓ <%= @subtask.title %></p>
    <% if @subtask.due_date %>
      <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-top:8px;">
        <%= email_detail_row(t('mailers.subtask.assigned.field_due'), email_date(@subtask.due_date)) %>
      </table>
    <% end %>
  </td></tr>
</table>

<%= email_button(t('mailers.subtask.assigned.button'), @ticket_url) %>

<p style="margin:20px 0 0;font-size:13px;line-height:1.5;color:#8B86A3;">
  <%= t('mailers.subtask.assigned.note') %>
</p>
