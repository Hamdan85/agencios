<% content_for :preheader do %>Uma tarefa foi atribuída a você: <%= @subtask.title %>.<% end %>
<% content_for :eyebrow do %>Tarefa<% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  Nova tarefa para você
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  Olá, <%= @assignee.display_name %>.
  <% if @actor_name %><strong><%= @actor_name %></strong> atribuiu<% else %>Foi atribuída<% end %>
  uma tarefa a você no ticket <strong><%= @ticket.display_title %></strong>.
</p>

<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin:8px 0 20px;background-color:#F5F4FB;border-radius:14px;">
  <tr><td style="padding:18px 20px;">
    <p style="margin:0;font-size:16px;font-weight:700;color:#18122B;">✓ <%= @subtask.title %></p>
    <% if @subtask.due_date %>
      <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-top:8px;">
        <%= email_detail_row("Prazo", email_date(@subtask.due_date)) %>
      </table>
    <% end %>
  </td></tr>
</table>

<%= email_button("Ver no ticket", @ticket_url) %>

<p style="margin:20px 0 0;font-size:13px;line-height:1.5;color:#8B86A3;">
  Suas tarefas ficam reunidas em “Minhas tarefas”.
</p>
