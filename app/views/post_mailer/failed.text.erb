<%= t('mailers.common.hello') %>, <%= @recipient.display_name %>!

<%= t('mailers.post.failed.text_body', title: @ticket.display_title, provider: @provider) %>
<% if @reason.present? %>
<%= t('mailers.post.failed.text_reason') %> <%= @reason %>
<% end %>
<%= t('mailers.post.failed.text_retry') %> <%= @ticket_url %>
