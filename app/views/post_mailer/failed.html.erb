<% content_for :preheader do %><%= t('mailers.post.failed.preheader', provider: @provider) %><% end %>
<% content_for :eyebrow do %><%= t('mailers.post.failed.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.post.failed.heading') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %>, <%= @recipient.display_name %>. <%= t('mailers.post.failed.body_html', title: @ticket.display_title, provider: @provider) %>
</p>

<% if @reason.present? %>
  <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin:8px 0 20px;background-color:#FEF2F2;border-radius:14px;">
    <tr><td style="padding:16px 20px;font-size:13px;line-height:1.5;color:#B91C1C;">
      <%= @reason %>
    </td></tr>
  </table>
<% end %>

<p style="margin:0 0 16px;font-size:14px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.post.failed.retry_hint') %>
</p>

<%= email_button(t('mailers.post.failed.button'), @ticket_url, color: "#F43F5E") %>
