<% content_for :preheader do %><%= t('mailers.post.published.preheader', provider: @provider) %><% end %>
<% content_for :eyebrow do %><%= t('mailers.post.published.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.post.published.heading') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %>, <%= @recipient.display_name %>. <%= t('mailers.post.published.body_html', title: @ticket.display_title, provider: @provider) %>
</p>

<% if @post.permalink.present? %>
  <%= email_button(t('mailers.post.published.button'), @post.permalink) %>
  <p style="margin:16px 0 0;font-size:14px;line-height:1.6;color:#564F6F;">
    <%= t('mailers.post.published.follow_html', url: @ticket_url) %>
  </p>
<% else %>
  <%= email_button(t('mailers.common.open_ticket'), @ticket_url) %>
<% end %>
