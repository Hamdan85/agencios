<%= t('mailers.common.hello') %>, <%= @assignee.display_name %>!

<% if @actor_name %><%= t('mailers.ticket.assigned.text_assigned_by', name: @actor_name) %><% else %><%= t('mailers.ticket.assigned.text_assigned_generic') %><% end %> <%= t('mailers.ticket.assigned.text_body_suffix') %>

<%= @ticket.display_title %>
<% if @project %><%= t('mailers.ticket.assigned.text_campaign') %> <%= @project.name %>
<% end %><%= t('mailers.ticket.assigned.text_status') %> <%= status_label(@ticket.status) %>
<% if @ticket.due_date %><%= t('mailers.ticket.assigned.text_due') %> <%= email_date(@ticket.due_date) %>
<% end %>
<%= t('mailers.common.open_ticket') %>: <%= @ticket_url %>
