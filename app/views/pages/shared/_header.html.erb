<%# Sticky, dark-glass marketing header. Works over both the dark heroes and
    the light sections because it is a solid translucent dark bar. %>
<header data-header class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-brand-ink/60 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8">
    <%= link_to root_path, class: "flex items-center gap-2.5" do %>
      <img src="/icon.svg" alt="agencios" class="size-9 drop-shadow-md" />
      <span class="font-display text-lg font-extrabold tracking-tight text-white">agencios</span>
    <% end %>

    <%# ── Desktop nav ─────────────────────────────────────────────── %>
    <nav class="hidden items-center gap-1 md:flex">
      <%= link_to "Como funciona", how_it_works_path,
            class: "rounded-lg px-3 py-2 text-sm font-semibold transition #{nav_section_active?('/como-funciona') ? 'text-white' : 'text-white/60 hover:text-white'}" %>

      <%# Funcionalidades — CSS-only hover/focus dropdown %>
      <div class="group relative">
        <%= link_to features_path,
              class: "flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-semibold transition #{nav_section_active?('/funcionalidades') ? 'text-white' : 'text-white/60 hover:text-white'}" do %>
          Funcionalidades <%= icon "chevron-down", size: 14, css: "opacity-60 transition group-hover:rotate-180" %>
        <% end %>
        <div class="invisible absolute left-1/2 top-full w-72 -translate-x-1/2 pt-2 opacity-0 transition-all duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
          <div class="overflow-hidden rounded-2xl border border-border bg-surface p-2 shadow-2xl">
            <% @features_catalog.each do |f| %>
              <%= link_to feature_path(f[:slug]), class: "flex items-start gap-3 rounded-xl p-2.5 transition hover:bg-surface-muted" do %>
                <span class="flex size-9 shrink-0 items-center justify-center rounded-lg" style="background: <%= soft_bg(f[:color]) %>; color: <%= f[:color] %>;">
                  <%= icon f[:icon], size: 18, stroke: 2.2 %>
                </span>
                <span class="min-w-0">
                  <span class="block text-sm font-bold text-ink"><%= f[:name] %></span>
                  <span class="block truncate text-xs text-ink-muted"><%= f[:eyebrow] %></span>
                </span>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>

      <%= link_to "Preços", pricing_path,
            class: "rounded-lg px-3 py-2 text-sm font-semibold transition #{nav_section_active?('/precos') ? 'text-white' : 'text-white/60 hover:text-white'}" %>
    </nav>

    <%# ── Right side CTAs ─────────────────────────────────────────── %>
    <div class="flex items-center gap-2">
      <%= link_to "Entrar", "/login", class: "hidden rounded-xl px-3.5 py-2 text-sm font-semibold text-white/80 transition hover:bg-white/10 hover:text-white sm:inline-flex" %>
      <%= link_to "/cadastro", class: "inline-flex h-9 items-center gap-1.5 rounded-xl bg-brand-gradient px-3.5 text-[13px] font-semibold text-white shadow-[0_8px_20px_-8px_rgba(124,58,237,0.7)] transition hover:brightness-105" do %>
        Começar grátis <%= icon "arrow-right", size: 15 %>
      <% end %>
      <button type="button" data-mobile-open aria-label="Abrir menu" class="inline-flex size-9 items-center justify-center rounded-xl text-white/80 transition hover:bg-white/10 md:hidden">
        <%= icon "menu", size: 20 %>
      </button>
    </div>
  </div>
</header>

<%# ── Mobile drawer ─────────────────────────────────────────────── %>
<div data-mobile-nav class="fixed inset-0 z-[60] hidden md:hidden">
  <div data-mobile-close class="absolute inset-0 bg-brand-ink/70 backdrop-blur-sm"></div>
  <div class="absolute right-0 top-0 flex h-full w-[84%] max-w-sm flex-col bg-shell-gradient p-5">
    <div class="flex items-center justify-between">
      <span class="flex items-center gap-2.5">
        <img src="/icon.svg" alt="agencios" class="size-9 drop-shadow-md" />
        <span class="font-display text-lg font-extrabold text-white">agencios</span>
      </span>
      <button type="button" data-mobile-close aria-label="Fechar menu" class="inline-flex size-9 items-center justify-center rounded-xl text-white/80 transition hover:bg-white/10">
        <%= icon "x", size: 20 %>
      </button>
    </div>

    <nav class="mt-8 flex flex-col gap-1">
      <%= link_to "Como funciona", how_it_works_path, class: "rounded-xl px-3 py-3 text-base font-semibold text-white/80 transition hover:bg-white/10 hover:text-white" %>
      <%= link_to "Funcionalidades", features_path, class: "rounded-xl px-3 py-3 text-base font-semibold text-white/80 transition hover:bg-white/10 hover:text-white" %>
      <div class="ml-2 flex flex-col gap-0.5 border-l border-white/10 pl-3">
        <% @features_catalog.each do |f| %>
          <%= link_to feature_path(f[:slug]), class: "flex items-center gap-2.5 rounded-lg px-2.5 py-2 text-sm font-medium text-white/55 transition hover:bg-white/10 hover:text-white" do %>
            <span class="flex size-7 items-center justify-center rounded-lg" style="background: <%= soft_bg(f[:color]) %>; color: <%= f[:color] %>;">
              <%= icon f[:icon], size: 15, stroke: 2.2 %>
            </span>
            <%= f[:name] %>
          <% end %>
        <% end %>
      </div>
      <%= link_to "Preços", pricing_path, class: "rounded-xl px-3 py-3 text-base font-semibold text-white/80 transition hover:bg-white/10 hover:text-white" %>
    </nav>

    <div class="mt-auto flex flex-col gap-2.5 pt-6">
      <%= link_to "Entrar", "/login", class: "inline-flex h-11 items-center justify-center rounded-xl border border-white/15 bg-white/5 text-sm font-semibold text-white transition hover:bg-white/10" %>
      <%= link_to "/cadastro", class: "inline-flex h-11 items-center justify-center gap-1.5 rounded-xl bg-brand-gradient text-sm font-semibold text-white shadow-lg transition hover:brightness-105" do %>
        Começar grátis <%= icon "arrow-right", size: 16 %>
      <% end %>
    </div>
  </div>
</div>
