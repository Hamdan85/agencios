<%# A stylised in-app preview per feature, inside a browser-style window frame.
    Local: feature (a FEATURES entry). %>
<% c = feature[:color] %>
<div class="relative">
  <div class="absolute -inset-6 bg-aurora opacity-50 blur-3xl"></div>
  <div class="relative overflow-hidden rounded-3xl border border-border bg-surface shadow-[0_30px_80px_-40px_rgba(24,18,43,0.45)]">
    <%# Window chrome %>
    <div class="flex items-center gap-1.5 border-b border-border bg-surface-muted px-4 py-3">
      <span class="size-2.5 rounded-full bg-rose/70"></span>
      <span class="size-2.5 rounded-full bg-amber/70"></span>
      <span class="size-2.5 rounded-full bg-emerald/70"></span>
      <span class="ml-3 inline-flex items-center gap-1.5 rounded-md bg-surface px-2 py-0.5 font-mono text-[11px] text-ink-muted">
        <span class="size-3.5" style="color: <%= c %>;"><%= icon feature[:icon], size: 14, stroke: 2.4 %></span>
        agencios.app/<%= feature[:slug] %>
      </span>
    </div>

    <div class="p-5">
      <% case feature[:slug] %>
      <% when "quadro" %>
        <div class="flex gap-3 overflow-hidden">
          <% [["Ideação", "#F59E0B", 2], ["Produção", "#7C3AED", 2], ["Agendado", "#EC4899", 1]].each do |label, col, n| %>
            <div class="w-full">
              <div class="mb-2 flex items-center gap-1.5 rounded-lg px-2 py-1.5 text-xs font-bold" style="background: <%= col %>16; color: <%= col %>;">
                <span class="size-2 rounded-full" style="background: <%= col %>;"></span> <%= label %>
              </div>
              <div class="space-y-2">
                <% n.times do %>
                  <div class="rounded-xl border border-border bg-canvas p-3 shadow-sm">
                    <div class="h-1.5 w-9 rounded-full" style="background: <%= col %>;"></div>
                    <div class="mt-2 h-2 w-full rounded bg-surface-muted"></div>
                    <div class="mt-1.5 h-2 w-2/3 rounded bg-surface-muted"></div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

      <% when "estudio" %>
        <div class="grid grid-cols-3 gap-3">
          <% 3.times do |i| %>
            <div class="aspect-[4/5] rounded-xl border border-border" style="background: linear-gradient(160deg, <%= c %><%= %w[26 1f 14][i] %>, <%= c %>0a);">
              <div class="flex h-full flex-col justify-between p-2.5">
                <span class="inline-flex w-fit items-center gap-1 rounded-full bg-surface/80 px-1.5 py-0.5 font-mono text-[9px] font-bold" style="color: <%= c %>;"><%= i + 1 %>/3</span>
                <div>
                  <div class="h-1.5 w-3/4 rounded-full bg-surface/80"></div>
                  <div class="mt-1 h-1.5 w-1/2 rounded-full bg-surface/60"></div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        <div class="mt-3 flex items-center gap-2 rounded-xl border border-border bg-canvas p-3">
          <span class="flex size-8 items-center justify-center rounded-lg" style="background: <%= soft_bg(c) %>; color: <%= c %>;"><%= icon "wand-sparkles", size: 16 %></span>
          <div class="min-w-0 flex-1">
            <div class="h-2 w-1/3 rounded bg-surface-muted"></div>
            <div class="mt-2 h-1.5 w-full overflow-hidden rounded-full bg-surface-muted">
              <div class="h-full w-2/3 rounded-full" style="background: <%= c %>;"></div>
            </div>
          </div>
          <span class="rounded-md px-2 py-1 text-[10px] font-bold" style="background: <%= soft_bg(c) %>; color: <%= c %>;">Gerando…</span>
        </div>

      <% when "inteligencia" %>
        <div class="space-y-3">
          <div class="rounded-xl border border-border bg-canvas p-3.5">
            <div class="mb-2 flex items-center gap-1.5 text-xs font-bold" style="color: <%= c %>;"><%= icon "sparkles", size: 14 %> Resumo da IA</div>
            <div class="space-y-1.5">
              <div class="h-2 w-full rounded bg-surface-muted"></div>
              <div class="h-2 w-11/12 rounded bg-surface-muted"></div>
              <div class="h-2 w-3/4 rounded bg-surface-muted"></div>
            </div>
          </div>
          <div class="flex flex-wrap gap-2">
            <% ["Gancho 1", "Gancho 2", "Ângulo viral", "+3 ideias"].each do |chip| %>
              <span class="rounded-full border border-border bg-surface px-2.5 py-1 text-xs font-semibold text-ink-secondary"><%= chip %></span>
            <% end %>
          </div>
          <div class="rounded-xl border border-border bg-canvas p-3.5">
            <div class="mb-2 flex items-center gap-1.5 text-xs font-bold text-ink-muted"><%= icon "list-checks", size: 14 %> Escopo gerado</div>
            <% 3.times do |i| %>
              <div class="flex items-center gap-2 py-1">
                <span class="flex size-4 items-center justify-center rounded" style="background: <%= soft_bg(c) %>; color: <%= c %>;"><%= icon "check", size: 11, stroke: 3 %></span>
                <div class="h-2 rounded bg-surface-muted" style="width: <%= [70, 55, 80][i] %>%;"></div>
              </div>
            <% end %>
          </div>
        </div>

      <% when "publicacao" %>
        <div class="flex flex-wrap gap-2">
          <% [["Instagram", "#E1306C"], ["Facebook", "#1877F2"], ["Threads", "#18122B"], ["TikTok", "#18122B"], ["YouTube", "#FF0000"], ["LinkedIn", "#0A66C2"], ["X", "#18122B"]].each do |net, nc| %>
            <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-canvas px-2.5 py-1 text-xs font-semibold text-ink-secondary">
              <span class="size-2 rounded-full" style="background: <%= nc %>;"></span> <%= net %>
            </span>
          <% end %>
        </div>
        <div class="mt-3 grid grid-cols-2 gap-3">
          <div class="rounded-xl border border-border bg-canvas p-3.5">
            <div class="text-[11px] font-bold uppercase tracking-wider text-ink-muted">Alcance</div>
            <div class="mt-1 font-display text-2xl font-extrabold text-ink">128k</div>
            <div class="mt-2 flex h-12 items-end gap-1">
              <% [40, 65, 50, 80, 70, 95, 88].each do |h| %>
                <span class="flex-1 rounded-t" style="height: <%= h %>%; background: <%= c %>;"></span>
              <% end %>
            </div>
          </div>
          <div class="rounded-xl border border-border bg-canvas p-3.5">
            <div class="text-[11px] font-bold uppercase tracking-wider text-ink-muted">Engajamento</div>
            <div class="mt-1 font-display text-2xl font-extrabold text-ink">7,4%</div>
            <div class="mt-3 space-y-2">
              <% [["Curtidas", 80], ["Salvos", 55], ["Comentários", 35]].each do |m, w| %>
                <div>
                  <div class="mb-1 flex justify-between text-[10px] font-semibold text-ink-muted"><span><%= m %></span></div>
                  <div class="h-1.5 w-full overflow-hidden rounded-full bg-surface-muted"><div class="h-full rounded-full" style="width: <%= w %>%; background: <%= c %>;"></div></div>
                </div>
              <% end %>
            </div>
          </div>
        </div>

      <% when "calendario" %>
        <div class="grid grid-cols-7 gap-1.5">
          <% %w[S T Q Q S S D].each do |d| %>
            <div class="pb-1 text-center text-[10px] font-bold uppercase text-ink-muted"><%= d %></div>
          <% end %>
          <% events = { 3 => "#EC4899", 8 => "#10B981", 9 => "#0EA5E9", 14 => "#7C3AED", 17 => "#F59E0B", 22 => "#EC4899", 23 => "#10B981", 28 => "#6366F1" } %>
          <% (1..28).each do |day| %>
            <div class="aspect-square rounded-lg border border-border bg-canvas p-1">
              <div class="text-[10px] font-semibold text-ink-muted"><%= day %></div>
              <% if events[day] %>
                <div class="mt-0.5 h-1.5 w-full rounded-full" style="background: <%= events[day] %>;"></div>
              <% end %>
            </div>
          <% end %>
        </div>
        <div class="mt-3 flex items-center gap-3 text-[11px] font-semibold text-ink-muted">
          <span class="inline-flex items-center gap-1.5"><span class="size-2 rounded-full bg-pink"></span> Post agendado</span>
          <span class="inline-flex items-center gap-1.5"><span class="size-2 rounded-full bg-indigo"></span> Reunião</span>
        </div>

      <% when "cobrancas" %>
        <div class="rounded-2xl border border-border bg-canvas p-4">
          <div class="flex items-start justify-between">
            <div>
              <div class="text-[11px] font-bold uppercase tracking-wider text-ink-muted">Fatura #0042</div>
              <div class="mt-1 font-display text-2xl font-extrabold text-ink">R$ 4.500,00</div>
            </div>
            <span class="rounded-full px-2.5 py-1 text-xs font-bold" style="background: #10B98114; color: #10B981;">Pago</span>
          </div>
          <div class="mt-4 flex items-center gap-3">
            <div class="grid size-16 shrink-0 grid-cols-4 grid-rows-4 gap-0.5 rounded-lg border border-border bg-surface p-1.5">
              <% 16.times do |i| %>
                <span class="rounded-[1px]" style="background: <%= [0, 1, 3, 4, 6, 9, 10, 12, 15].include?(i) ? '#18122B' : 'transparent' %>;"></span>
              <% end %>
            </div>
            <div class="min-w-0 flex-1">
              <div class="inline-flex items-center gap-1.5 rounded-md px-2 py-1 text-xs font-bold" style="background: <%= soft_bg(c) %>; color: <%= c %>;"><%= icon "zap", size: 13 %> Pix · Mercado Pago</div>
              <div class="mt-2 space-y-1.5">
                <div class="h-2 w-3/4 rounded bg-surface-muted"></div>
                <div class="h-2 w-1/2 rounded bg-surface-muted"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-3 flex items-center gap-2 rounded-xl border border-border bg-canvas p-3 text-xs font-semibold text-ink-muted">
          <%= icon "repeat", size: 14, css: "shrink-0" %> Conciliação automática a cada sincronização.
        </div>

      <% when "estrategista" %>
        <div class="space-y-2.5">
          <div class="ml-auto max-w-[85%] rounded-2xl rounded-br-md px-3.5 py-2 text-[11px] text-white shadow" style="background: <%= c %>;">
            2 reels e 1 carrossel por semana, foco em prova social.
          </div>
          <div class="flex items-start gap-2">
            <span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-lg" style="background: <%= soft_bg(c) %>; color: <%= c %>;"><%= icon "bot", size: 12 %></span>
            <div class="max-w-[85%] rounded-2xl rounded-bl-md bg-canvas px-3.5 py-2 text-[11px] text-ink-secondary">Montei um plano de 4 semanas — 12 tickets prontos. Aplicar?</div>
          </div>
        </div>
        <div class="mt-3 rounded-xl border border-border bg-canvas p-3">
          <div class="mb-2 flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-wider" style="color: <%= c %>;"><%= icon "circle-check", size: 12 %> 12 tickets propostos</div>
          <div class="grid grid-cols-2 gap-1.5">
            <% [["Reel — bastidores", "#F59E0B"], ["Carrossel — 5 mitos", "#0EA5E9"], ["Reel — depoimento", "#F59E0B"], ["Carrossel — passo a passo", "#0EA5E9"]].each do |title, tc| %>
              <div class="rounded-lg border border-border bg-surface p-2">
                <span class="inline-block h-1.5 w-6 rounded-full" style="background: <%= tc %>;"></span>
                <p class="mt-1 text-[10px] font-medium leading-tight text-ink-secondary"><%= title %></p>
              </div>
            <% end %>
          </div>
          <div class="mt-2.5 flex h-8 items-center justify-center gap-1.5 rounded-lg text-[11px] font-bold text-white" style="background: <%= c %>;"><%= icon "check", size: 13, stroke: 3 %> Aplicar no quadro</div>
        </div>

      <% when "relatorios" %>
        <div class="rounded-2xl border border-border bg-canvas p-4">
          <div class="flex items-center justify-between">
            <div class="text-[11px] font-bold uppercase tracking-wider text-ink-muted">Relatório · Campanha Bloom</div>
            <span class="rounded-full px-2 py-0.5 text-[10px] font-bold" style="background: <%= soft_bg(c) %>; color: <%= c %>;">90 dias</span>
          </div>
          <div class="mt-3 grid grid-cols-3 gap-2">
            <% [["Alcance", "+42%"], ["Posts", "24"], ["Meta", "118%"]].each do |label, val| %>
              <div class="rounded-lg border border-border bg-surface p-2 text-center">
                <p class="font-display text-base font-extrabold" style="color: <%= c %>;"><%= val %></p>
                <p class="text-[9px] font-medium text-ink-muted"><%= label %></p>
              </div>
            <% end %>
          </div>
          <div class="mt-3 space-y-1.5">
            <div class="flex items-center gap-1.5 rounded-lg bg-emerald/8 px-2 py-1.5 text-[10px] text-ink-secondary"><span class="text-emerald"><%= icon "trophy", size: 12 %></span> Acerto: bastidores puxaram o alcance</div>
            <div class="flex items-center gap-1.5 rounded-lg bg-amber/8 px-2 py-1.5 text-[10px] text-ink-secondary"><span class="text-amber"><%= icon "target", size: 12 %></span> Ajuste: publicar mais cedo às terças</div>
            <div class="flex items-center gap-1.5 rounded-lg px-2 py-1.5 text-[10px] text-ink-secondary" style="background: <%= soft_bg(c) %>;"><span style="color: <%= c %>;"><%= icon "sparkles", size: 12 %></span> Gerado e revisado com IA</div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
