<%# A stylised preview of the production board (the 7-stage Kanban).
    Local: funnel (the FUNNEL array). %>
<div class="relative mx-auto mt-14 max-w-5xl">
  <div class="absolute -inset-x-8 -top-8 bottom-0 bg-aurora opacity-60 blur-2xl"></div>
  <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-brand-ink2/80 p-3 shadow-2xl backdrop-blur">
    <div class="flex items-center gap-1.5 px-2 pb-2.5 pt-1">
      <span class="size-2.5 rounded-full bg-rose/80"></span>
      <span class="size-2.5 rounded-full bg-amber/80"></span>
      <span class="size-2.5 rounded-full bg-emerald/80"></span>
      <span class="ml-3 font-mono text-[11px] text-white/40">quadro · produção</span>
    </div>
    <div class="flex gap-3 overflow-x-auto rounded-2xl bg-canvas p-4 no-scrollbar">
      <% funnel.each_with_index do |s, col| %>
        <div class="w-44 shrink-0">
          <div class="mb-2 flex items-center gap-1.5 rounded-lg px-2 py-1.5" style="background: <%= soft_bg(s[:color]) %>; color: <%= s[:color] %>;">
            <%= icon s[:icon], size: 14, stroke: 2.5 %>
            <span class="text-xs font-bold"><%= s[:label] %></span>
          </div>
          <div class="space-y-2">
            <% (col.even? ? 2 : 1).times do %>
              <div class="rounded-xl border border-border bg-surface p-3 shadow-sm">
                <div class="h-1.5 w-10 rounded-full" style="background: <%= s[:color] %>;"></div>
                <div class="mt-2 h-2 w-full rounded bg-surface-muted"></div>
                <div class="mt-1.5 h-2 w-2/3 rounded bg-surface-muted"></div>
                <div class="mt-3 flex items-center gap-1">
                  <span class="size-5 rounded-full" style="background: <%= s[:color] %>33;"></span>
                  <span class="h-1.5 w-8 rounded-full bg-surface-muted"></span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
