<% content_for :title, "#{@feature[:name]} — agencios" %>
<% content_for :description, @feature[:subhead] %>
<% c = @feature[:color] %>

<%# ── Hero ──────────────────────────────────────────────────────── %>
<section class="relative overflow-hidden bg-shell-gradient">
  <div class="absolute inset-0 bg-aurora opacity-70"></div>
  <div class="relative mx-auto max-w-6xl px-5 pb-20 pt-28 sm:px-8 sm:pt-36">
    <nav class="mb-8 flex items-center gap-1.5 text-xs font-semibold text-white/50">
      <%= link_to "Funcionalidades", features_path, class: "transition hover:text-white" %>
      <%= icon "chevron-right", size: 13 %>
      <span class="text-white/80"><%= @feature[:name] %></span>
    </nav>

    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1.5 text-xs font-bold text-white/80 ring-1 ring-white/10">
          <span style="color: <%= c %>;"><%= icon @feature[:icon], size: 14, stroke: 2.4 %></span> <%= @feature[:eyebrow] %>
        </span>
        <h1 class="mt-5 font-display text-4xl font-extrabold leading-[1.08] tracking-tight text-white sm:text-5xl">
          <%= @feature[:headline] %>
        </h1>
        <p class="mt-5 max-w-lg text-lg text-white/70"><%= @feature[:subhead] %></p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <%= link_to "/cadastro", class: "inline-flex h-12 items-center gap-2 rounded-xl bg-brand-gradient px-6 text-base font-semibold text-white shadow-[0_10px_28px_-8px_rgba(124,58,237,0.7)] transition hover:brightness-105" do %>
            Começar grátis <%= icon "arrow-right", size: 18 %>
          <% end %>
          <%= link_to "Ver planos", pricing_path, class: "inline-flex h-12 items-center gap-2 rounded-xl border border-white/20 bg-white/5 px-6 text-base font-semibold text-white transition hover:bg-white/10" %>
        </div>
        <ul class="mt-8 flex flex-wrap gap-x-5 gap-y-2">
          <% @feature[:highlights].each do |h| %>
            <li class="inline-flex items-center gap-1.5 text-sm font-medium text-white/70">
              <span style="color: <%= c %>;"><%= icon "circle-check", size: 16 %></span> <%= h %>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="reveal">
        <%= render "pages/shared/feature_mockup", feature: @feature %>
      </div>
    </div>
  </div>
</section>

<%# ── Detail points ─────────────────────────────────────────────── %>
<section class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-24">
  <div class="max-w-2xl reveal">
    <p class="text-xs font-bold uppercase tracking-[0.16em]" style="color: <%= c %>;">Por dentro</p>
    <h2 class="mt-2 font-display text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">O que você ganha com <%= @feature[:name] %></h2>
  </div>
  <div class="mt-12 grid gap-6 sm:grid-cols-2" data-reveal-group data-reveal-step="80">
    <% @feature[:points].each do |p| %>
      <div class="rounded-2xl border border-border bg-surface p-6 lift reveal reveal-scale">
        <span class="flex size-12 items-center justify-center rounded-2xl" style="background: <%= soft_bg(c) %>; color: <%= c %>;">
          <%= icon p[:icon], size: 24, stroke: 2.2 %>
        </span>
        <h3 class="mt-4 font-display text-lg font-bold text-ink"><%= p[:title] %></h3>
        <p class="mt-1.5 text-sm leading-relaxed text-ink-muted"><%= p[:desc] %></p>
      </div>
    <% end %>
  </div>
</section>

<%# ── Related features ──────────────────────────────────────────── %>
<section class="bg-surface py-20 sm:py-24">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="flex items-end justify-between reveal">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.16em] text-brand">Combina com</p>
        <h2 class="mt-2 font-display text-2xl font-extrabold tracking-tight text-ink sm:text-3xl">Outras funcionalidades</h2>
      </div>
      <%= link_to "Ver todas", features_path, class: "hidden items-center gap-1.5 text-sm font-semibold text-brand transition hover:gap-2.5 sm:inline-flex" %>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      <% @related.each do |f| %>
        <%= link_to feature_path(f[:slug]), class: "group block rounded-2xl border border-border bg-canvas p-6 lift" do %>
          <span class="flex size-12 items-center justify-center rounded-2xl" style="background: <%= soft_bg(f[:color]) %>; color: <%= f[:color] %>;">
            <%= icon f[:icon], size: 24, stroke: 2.2 %>
          </span>
          <h3 class="mt-4 flex items-center gap-1.5 font-display text-lg font-bold text-ink">
            <%= f[:name] %>
            <span class="text-ink-faint transition-all group-hover:translate-x-0.5 group-hover:text-brand"><%= icon "arrow-right", size: 16 %></span>
          </h3>
          <p class="mt-1.5 text-sm leading-relaxed text-ink-muted"><%= f[:card] %></p>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<%= render "pages/shared/cta" %>
