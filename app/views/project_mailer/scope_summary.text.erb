<%= t('mailers.common.hello') %><%= @client&.name.present? ? ", #{@client.name}" : "" %>!

<%= t('mailers.project.scope_summary.text_body', project: @project.name) %>

<% if @tickets.any? %>
<% @tickets.each do |ticket| %>
- <%= ticket.display_title %>
  <%= ticket.creative_types_list.map { |type| creative_type_label(type) }.join(" · ").presence || "—" %> · <%= status_label(ticket.status) %> · <%= ticket.scheduled_at ? email_date(ticket.scheduled_at) : t('mailers.project.scope_summary.date_tbd') %>
<% end %>
<% else %>
<%= t('mailers.project.scope_summary.empty') %>
<% end %>
<%= t('mailers.project.scope_summary.footer') %>
