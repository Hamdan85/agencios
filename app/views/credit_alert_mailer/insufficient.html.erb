<% content_for :preheader do %><%= t('mailers.credit_alert.insufficient.preheader') %><% end %>
<% content_for :eyebrow do %><%= t('mailers.credit_alert.insufficient.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.credit_alert.insufficient.heading') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.credit_alert.insufficient.body_intro') %><%= @context ? " (#{@context})" : "" %>.
  <% if @required&.positive? %><%= t('mailers.credit_alert.insufficient.body_required_html', count: @required) %><% end %>
  <%= t('mailers.credit_alert.insufficient.body_outro') %>
</p>

<%= email_button(t('mailers.credit_alert.insufficient.button'), @url) %>

<p style="margin:16px 0 0;font-size:13px;line-height:1.5;color:#8B86A3;">
  <%= t('mailers.credit_alert.insufficient.note') %>
</p>
