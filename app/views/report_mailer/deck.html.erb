<% content_for :preheader do %><%= t('mailers.report.deck.preheader', project: @project.name) %><% end %>
<% content_for :eyebrow do %><%= t('mailers.report.deck.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.report.deck.heading', project: @project.name) %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %><%= @client&.name.present? ? ", #{@client.name}" : "" %>. <%= t('mailers.report.deck.body_html', project: @project.name) %>
</p>

<%= email_button(t('mailers.report.deck.button'), @url) %>

<p style="margin:16px 0 0;font-size:13px;line-height:1.5;color:#8B86A3;">
  <%= t('mailers.report.deck.note') %>
</p>
