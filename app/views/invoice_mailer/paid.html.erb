<% content_for :preheader do %><%= t('mailers.invoice.paid.preheader', amount: email_brl(@invoice.amount_cents)) %><% end %>
<% content_for :eyebrow do %><%= t('mailers.invoice.paid.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.invoice.paid.heading') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %><%= @client.name.present? ? ", #{@client.name}" : "" %>. <%= t('mailers.invoice.paid.body_html', workspace: @workspace.name) %>
</p>

<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin:8px 0 20px;background-color:#ECFDF5;border-radius:14px;">
  <tr><td style="padding:18px 20px;">
    <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0">
      <%= email_detail_row(t('mailers.invoice.fields.reference'), @invoice.external_reference.to_s) %>
      <% if @invoice.description.present? %><%= email_detail_row(t('mailers.invoice.fields.description'), @invoice.description) %><% end %>
      <tr>
        <td style="padding:12px 0 0;font-size:15px;font-weight:700;color:#18122B;border-top:1px solid #C7F0DD;"><%= t('mailers.invoice.fields.amount_paid') %></td>
        <td align="right" style="padding:12px 0 0;font-size:18px;font-weight:800;color:#10B981;border-top:1px solid #C7F0DD;"><%= email_brl(@invoice.amount_cents) %></td>
      </tr>
    </table>
  </td></tr>
</table>

<p style="margin:0;font-size:13px;line-height:1.5;color:#8B86A3;"><%= t('mailers.invoice.paid.keep_receipt') %></p>
