<% content_for :preheader do %>Recebemos seu pagamento de <%= email_brl(@invoice.amount_cents) %>. Obrigado!<% end %>
<% content_for :eyebrow do %>Recibo<% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  Pagamento confirmado 💸
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  Olá<%= @client.name.present? ? ", #{@client.name}" : "" %>. Recebemos seu pagamento. Obrigado por contar com a <strong><%= @workspace.name %></strong>!
</p>

<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin:8px 0 20px;background-color:#ECFDF5;border-radius:14px;">
  <tr><td style="padding:18px 20px;">
    <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0">
      <%= email_detail_row("Referência", @invoice.external_reference.to_s) %>
      <% if @invoice.description.present? %><%= email_detail_row("Descrição", @invoice.description) %><% end %>
      <tr>
        <td style="padding:12px 0 0;font-size:15px;font-weight:700;color:#18122B;border-top:1px solid #C7F0DD;">Valor pago</td>
        <td align="right" style="padding:12px 0 0;font-size:18px;font-weight:800;color:#10B981;border-top:1px solid #C7F0DD;"><%= email_brl(@invoice.amount_cents) %></td>
      </tr>
    </table>
  </td></tr>
</table>

<p style="margin:0;font-size:13px;line-height:1.5;color:#8B86A3;">Guarde este e-mail como comprovante.</p>
