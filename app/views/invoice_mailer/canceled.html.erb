<% content_for :preheader do %>Sua cobrança da <%= @workspace.name %> foi cancelada.<% end %>
<% content_for :eyebrow do %>Cobrança<% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  Cobrança cancelada
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  Olá<%= @client.name.present? ? ", #{@client.name}" : "" %>. A cobrança <strong><%= @invoice.external_reference %></strong>
  no valor de <strong><%= email_brl(@invoice.amount_cents) %></strong>, emitida pela <strong><%= @workspace.name %></strong>, foi cancelada.
  Nenhum pagamento é necessário.
</p>

<p style="margin:0;font-size:13px;line-height:1.5;color:#8B86A3;">
  Se tiver qualquer dúvida, fale diretamente com a <%= @workspace.name %>.
</p>
