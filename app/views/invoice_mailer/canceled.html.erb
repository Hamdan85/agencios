<% content_for :preheader do %><%= t('mailers.invoice.canceled.preheader', workspace: @workspace.name) %><% end %>
<% content_for :eyebrow do %><%= t('mailers.invoice.canceled.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.invoice.canceled.heading') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %><%= @client.name.present? ? ", #{@client.name}" : "" %>. <%= t('mailers.invoice.canceled.body_html', reference: @invoice.external_reference, amount: email_brl(@invoice.amount_cents), workspace: @workspace.name) %>
</p>

<p style="margin:0;font-size:13px;line-height:1.5;color:#8B86A3;">
  <%= t('mailers.invoice.canceled.note', workspace: @workspace.name) %>
</p>
