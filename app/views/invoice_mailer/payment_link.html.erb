<% content_for :preheader do %><%= t('mailers.invoice.payment_link.preheader', amount: email_brl(@invoice.amount_cents), workspace: @workspace.name) %><% end %>
<% content_for :eyebrow do %><%= t('mailers.invoice.payment_link.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.invoice.payment_link.heading') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %><%= @client.name.present? ? ", #{@client.name}" : "" %>. <%= t('mailers.invoice.payment_link.body_html', workspace: @workspace.name) %>
</p>

<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin:8px 0 20px;background-color:#F5F4FB;border-radius:14px;">
  <tr><td style="padding:18px 20px;">
    <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0">
      <%= email_detail_row(t('mailers.invoice.fields.reference'), @invoice.external_reference.to_s) %>
      <% if @invoice.description.present? %><%= email_detail_row(t('mailers.invoice.fields.description'), @invoice.description) %><% end %>
      <% if @invoice.due_date %><%= email_detail_row(t('mailers.invoice.fields.due_date'), email_date(@invoice.due_date)) %><% end %>
      <tr>
        <td style="padding:12px 0 0;font-size:15px;font-weight:700;color:#18122B;border-top:1px solid #E8E6F2;"><%= t('mailers.invoice.fields.total') %></td>
        <td align="right" style="padding:12px 0 0;font-size:18px;font-weight:800;color:#7C3AED;border-top:1px solid #E8E6F2;"><%= email_brl(@invoice.amount_cents) %></td>
      </tr>
    </table>
  </td></tr>
</table>

<%= email_button(t('mailers.invoice.pay_now'), @payment_url) %>
<p style="margin:16px 0 0;font-size:13px;line-height:1.5;color:#8B86A3;"><%= t('mailers.invoice.mercadopago_secure') %></p>
