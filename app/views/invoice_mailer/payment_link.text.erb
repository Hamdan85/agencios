<%= t('mailers.common.hello') %><%= @client.name.present? ? ", #{@client.name}" : "" %>!

<%= t('mailers.invoice.payment_link.text_body', workspace: @workspace.name) %>

<%= t('mailers.invoice.fields.reference') %>: <%= @invoice.external_reference %>
<% if @invoice.description.present? %><%= t('mailers.invoice.fields.description') %>: <%= @invoice.description %>
<% end %><% if @invoice.due_date %><%= t('mailers.invoice.fields.due_date') %>: <%= email_date(@invoice.due_date) %>
<% end %><%= t('mailers.invoice.fields.total') %>: <%= email_brl(@invoice.amount_cents) %>

<%= t('mailers.invoice.pay_now') %>: <%= @payment_url %>
<%= t('mailers.invoice.mercadopago_short') %>
