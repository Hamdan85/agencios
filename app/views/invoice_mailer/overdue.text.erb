<%= t('mailers.common.hello') %><%= @client.name.present? ? ", #{@client.name}" : "" %>!

<%= t('mailers.invoice.overdue.text_body', workspace: @workspace.name) %>

<%= t('mailers.invoice.fields.reference') %>: <%= @invoice.external_reference %>
<% if @invoice.due_date %><%= t('mailers.invoice.fields.due_on') %>: <%= email_date(@invoice.due_date) %>
<% end %><%= t('mailers.invoice.fields.total') %>: <%= email_brl(@invoice.amount_cents) %>
<% if @payment_url.present? %>
<%= t('mailers.invoice.overdue.button') %>: <%= @payment_url %>
<% end %>
<%= t('mailers.invoice.overdue.text_note') %>
