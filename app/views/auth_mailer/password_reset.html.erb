<% content_for :preheader do %>Redefina sua senha da agencios. O link expira em 20 minutos.<% end %>
<% content_for :eyebrow do %>Segurança<% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  Redefinição de senha
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  Olá, <%= @user.display_name %>. Recebemos um pedido para redefinir a senha da sua conta na <strong>agencios</strong>.
  Clique no botão abaixo para criar uma nova senha.
</p>

<%= email_button("Redefinir minha senha", @reset_url) %>

<p style="margin:20px 0 0;font-size:13px;line-height:1.5;color:#8B86A3;">
  Este link expira em 20 minutos. Se você não solicitou a redefinição, ignore este e-mail — sua senha permanece a mesma.
</p>
