<% content_for :preheader do %>Confirme seu novo endereço de e-mail na agencios.<% end %>
<% content_for :eyebrow do %>Segurança<% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  Confirme seu novo e-mail
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  Olá, <%= @user.display_name %>. Recebemos um pedido para alterar o e-mail da sua conta na
  <strong>agencios</strong> para <strong><%= @new_email %></strong>. Confirme abaixo para concluir a troca.
</p>

<%= email_button("Confirmar novo e-mail", @confirm_url) %>

<p style="margin:20px 0 0;font-size:13px;line-height:1.5;color:#8B86A3;">
  Este link expira em 24 horas. Se você não solicitou esta alteração, ignore este e-mail — seu
  e-mail atual permanece o mesmo.
</p>
