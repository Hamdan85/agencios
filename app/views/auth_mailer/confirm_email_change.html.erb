<% content_for :preheader do %><%= t('mailers.auth.confirm_email_change.preheader') %><% end %>
<% content_for :eyebrow do %><%= t('mailers.auth.confirm_email_change.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.auth.confirm_email_change.heading') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %>, <%= @user.display_name %>. <%= t('mailers.auth.confirm_email_change.body_html', email: @new_email) %>
</p>

<%= email_button(t('mailers.auth.confirm_email_change.button'), @confirm_url) %>

<p style="margin:20px 0 0;font-size:13px;line-height:1.5;color:#8B86A3;">
  <%= t('mailers.auth.confirm_email_change.note') %>
</p>
