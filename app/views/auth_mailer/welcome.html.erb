<% content_for :preheader do %><%= t('mailers.auth.welcome.preheader') %><% end %>
<% content_for :eyebrow do %><%= t('mailers.auth.welcome.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.common.hello') %>, <%= @user.display_name %> 👋
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.auth.welcome.body_html') %>
</p>

<%= email_button(t('mailers.auth.welcome.button'), @board_url) %>

<p style="margin:24px 0 0;font-size:14px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.auth.welcome.footer') %>
</p>
