<% content_for :preheader do %><%= t('mailers.auth.password_changed.preheader') %><% end %>
<% content_for :eyebrow do %><%= t('mailers.auth.password_changed.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.auth.password_changed.heading') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %>, <%= @user.display_name %>. <%= t('mailers.auth.password_changed.body_html') %>
</p>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.auth.password_changed.body2_html') %>
</p>

<%= email_button(t('mailers.auth.password_changed.button'), @support_url) %>
