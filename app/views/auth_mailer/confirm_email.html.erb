<% content_for :preheader do %>Confirme seu endereço de e-mail para ativar sua conta.<% end %>
<% content_for :eyebrow do %>Confirmação<% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  Confirme seu e-mail
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  Olá, <%= @user.display_name %>. Para ativar sua conta na <strong>agencios</strong> e proteger seu acesso,
  confirme que este é o seu endereço de e-mail.
</p>

<%= email_button("Confirmar e-mail", @confirm_url) %>

<p style="margin:20px 0 0;font-size:13px;line-height:1.5;color:#8B86A3;">
  Este link expira em 24 horas. Se você não criou uma conta na agencios, ignore este e-mail.
</p>
