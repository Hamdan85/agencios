<% content_for :preheader do %><%= t('mailers.subscription.trial_ending.preheader') %><% end %>
<% content_for :eyebrow do %><%= t('mailers.subscription.trial_ending.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.subscription.trial_ending.heading') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %><%= @owner&.display_name.present? ? ", #{@owner.display_name}" : "" %>. <%= t('mailers.subscription.trial_ending.body_prefix_html', workspace: @workspace.name) %>
  <% if @subscription&.trial_ends_at %><%= t('mailers.subscription.trial_ending.ends_on_html', date: email_date(@subscription.trial_ends_at)) %><% else %><%= t('mailers.subscription.trial_ending.ends_soon') %><% end %>.
</p>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.subscription.trial_ending.body2_html', plan: @plan_label) %>
</p>

<%= email_button(t('mailers.subscription.trial_ending.button'), @billing_url) %>
