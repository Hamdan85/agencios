<% content_for :preheader do %><%= t('mailers.subscription.payment_failed.preheader') %><% end %>
<% content_for :eyebrow do %><%= t('mailers.subscription.payment_failed.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.subscription.payment_failed.heading') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %><%= @owner&.display_name.present? ? ", #{@owner.display_name}" : "" %>. <%= t('mailers.subscription.payment_failed.body_html', plan: @plan_label, workspace: @workspace.name) %>
</p>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.subscription.payment_failed.body2') %>
</p>

<%= email_button(t('mailers.subscription.payment_failed.button'), @billing_url, color: "#F43F5E") %>
