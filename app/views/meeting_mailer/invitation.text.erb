<%= t('mailers.common.hello') %><%= @recipient_name.present? ? ", #{@recipient_name}" : "" %>!

<%= t('mailers.meeting.invitation.text_body', workspace: @workspace.name) %>

<%= @meeting.title %>
<%= t('mailers.meeting.invitation.text_start') %> <%= email_datetime(@meeting.starts_at) %>
<% if @meeting.ends_at %><%= t('mailers.meeting.invitation.text_end') %> <%= email_datetime(@meeting.ends_at) %>
<% end %><% if @meet_url.present? %>
<%= t('mailers.meeting.invitation.text_join') %> <%= @meet_url %>
<% end %><% if @meeting.notes.present? %>
<%= t('mailers.meeting.invitation.text_agenda') %> <%= @meeting.notes %>
<% end %>
