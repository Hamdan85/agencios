<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="csrf-token" content="<%= form_authenticity_token %>" />
    <meta name="theme-color" content="#0E0A1F" />
    <title>agencios — o sistema operacional da sua agência</title>

    <%# Favicon + PWA — installable app shell + iOS add-to-home-screen support %>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="agencios" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@400..800&family=Inter:opsz,wght@14..32,300..700&family=Space+Grotesk:wght@400..700&display=swap" />

    <%# Frontend error monitoring config (public browser DSN, safe to expose).
        Read from ENV so it can differ per environment; Sentry stays inert when
        SENTRY_FRONTEND_DSN is unset (e.g. local dev). %>
    <% if (sentry_dsn = ENV["SENTRY_FRONTEND_DSN"].presence) %>
      <script>
        window.__AGENCIOS_SENTRY = {
          dsn: <%= raw sentry_dsn.to_json %>,
          environment: <%= raw Rails.env.to_s.to_json %>
        }
      </script>
    <% end %>

    <%= vite_react_refresh_tag %>
    <%= vite_client_tag %>
    <%= vite_javascript_tag "application.jsx" %>
  </head>
  <body>
    <div id="root"></div>
    <%= render "pages/shared/cookie_consent" %>
  </body>
</html>
