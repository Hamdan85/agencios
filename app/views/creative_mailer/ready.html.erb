<% content_for :preheader do %><%= t('mailers.creative.ready.preheader', kind: @kind_label.downcase) %><% end %>
<% content_for :eyebrow do %><%= t('mailers.creative.ready.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.creative.ready.heading', kind: @kind_label) %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %>, <%= @user.display_name %>. <%= t('mailers.creative.ready.body_html', kind: @kind_label.downcase) %>
</p>

<%= email_button(t('mailers.creative.ready.button'), @url) %>
