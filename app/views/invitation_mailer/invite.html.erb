<% content_for :preheader do %><%= t('mailers.invitation.invite.preheader', workspace: @workspace.name) %><% end %>
<% content_for :eyebrow do %><%= t('mailers.invitation.invite.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.invitation.invite.heading') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <% if @inviter_name %><%= t('mailers.invitation.invite.invited_by_html', name: @inviter_name) %><% else %><%= t('mailers.invitation.invite.invited_generic') %><% end %>
  <%= t('mailers.invitation.invite.body_html', workspace: @workspace.name, role: @role_label) %>
</p>

<%= email_button(t('mailers.invitation.invite.button'), @link) %>

<p style="margin:20px 0 0;font-size:13px;line-height:1.5;color:#8B86A3;">
  <%= t('mailers.invitation.invite.note') %>
</p>
