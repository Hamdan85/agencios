<% content_for :preheader do %><%= @author_name %> mencionou você em <%= @ticket.display_title %>.<% end %>
<% content_for :eyebrow do %>Menção<% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  Você foi mencionado
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  Olá<%= @recipient.display_name.present? ? ", #{@recipient.display_name}" : "" %>.
  <strong><%= @author_name %></strong> mencionou você em um comentário no ticket
  <strong><%= @ticket.display_title %></strong>:
</p>

<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin:8px 0 20px;background-color:#F5F4FB;border-left:3px solid #7C3AED;border-radius:10px;">
  <tr><td style="padding:14px 18px;font-size:14px;line-height:1.6;color:#18122B;white-space:pre-wrap;"><%= @note.plain_body %></td></tr>
</table>

<%= email_button("Abrir ticket", @ticket_url) %>

<p style="margin:20px 0 0;font-size:13px;line-height:1.5;color:#8B86A3;">
  Você recebeu este e-mail porque foi mencionado neste ticket.
</p>
