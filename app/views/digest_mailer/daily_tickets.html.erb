<% content_for :preheader do %><%= t('mailers.digest.daily_tickets.preheader', count: @tickets_by_workspace.values.sum(&:size)) %><% end %>
<% content_for :eyebrow do %><%= t('mailers.digest.daily_tickets.eyebrow') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= t('mailers.digest.daily_tickets.heading') %>
</h1>

<p style="margin:0 0 20px;font-size:15px;line-height:1.6;color:#564F6F;">
  <%= t('mailers.common.hello') %><%= @user.display_name.present? ? ", #{@user.display_name}" : "" %>. <%= t('mailers.digest.daily_tickets.intro', date: email_date(@date)) %>
</p>

<% if @tickets_by_workspace.blank? %>
  <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin:8px 0 20px;background-color:#F5F4FB;border-radius:14px;">
    <tr><td style="padding:18px 20px;">
      <p style="margin:0;font-size:15px;line-height:1.6;color:#18122B;"><%= t('mailers.digest.daily_tickets.empty') %></p>
    </td></tr>
  </table>
<% else %>
  <% @tickets_by_workspace.each do |ws, tickets| %>
    <% if @tickets_by_workspace.size > 1 %>
      <p style="margin:24px 0 8px;font-size:13px;font-weight:700;letter-spacing:0.02em;text-transform:uppercase;color:#8B86A3;"><%= ws.name %></p>
    <% end %>
    <% tickets.each do |ticket| %>
      <% overdue = (ticket.due_date || ticket.scheduled_at&.to_date)&.past? %>
      <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin:0 0 10px;background-color:#F5F4FB;border-radius:14px;">
        <tr><td style="padding:16px 20px;">
          <table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0">
            <tr>
              <td valign="top">
                <a href="<%= app_url("/tickets/#{ticket.id}") %>" style="font-size:15px;font-weight:700;color:#18122B;text-decoration:none;"><%= ticket.display_title %></a>
                <p style="margin:4px 0 0;font-size:13px;color:#8B86A3;"><%= ticket.project&.name %></p>
              </td>
              <td valign="top" align="right" style="white-space:nowrap;">
                <span style="display:inline-block;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:600;color:#FFFFFF;background-color:<%= status_color(ticket.status) %>;"><%= status_label(ticket.status) %></span>
              </td>
            </tr>
          </table>
          <p style="margin:10px 0 0;font-size:13px;<%= overdue ? "color:#F43F5E;font-weight:600;" : "color:#8B86A3;" %>">
            <%= overdue ? t('mailers.digest.daily_tickets.overdue') : t('mailers.digest.daily_tickets.due_today') %> — <%= email_date(ticket.due_date || ticket.scheduled_at) %>
          </p>
        </td></tr>
      </table>
    <% end %>
  <% end %>
<% end %>

<%= email_button(t('mailers.digest.daily_tickets.button'), app_url("/tickets")) %>
