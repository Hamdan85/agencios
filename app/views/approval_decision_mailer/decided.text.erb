<%= @approved ? t('mailers.approval_decision.decided.heading_approved') : t('mailers.approval_decision.decided.heading_changes') %>

<%= @client&.name.presence || t('mailers.approval_decision.decided.default_client') %> <%= @approved ? t('mailers.approval_decision.decided.verb_approved') : t('mailers.approval_decision.decided.verb_changes') %> <%= @ticket.display_title %> (<%= @project.name %>)<%= @creative ? t('mailers.approval_decision.decided.piece_suffix', type: @creative.creative_type) : "" %>.
<% if !@approved && @feedback.present? %>
<%= t('mailers.approval_decision.decided.feedback_label_text') %>
<%= @feedback %>
<% end %>
<%= @approved ? t('mailers.approval_decision.decided.button_approved') : t('mailers.approval_decision.decided.button_changes') %>: <%= @url %>

<%= @approved ? t('mailers.approval_decision.decided.note_approved') : t('mailers.approval_decision.decided.note_changes') %>
