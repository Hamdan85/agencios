<% content_for :preheader do %><%= @approved ? t('mailers.approval_decision.decided.preheader_approved') : t('mailers.approval_decision.decided.preheader_changes') %> — <%= @ticket.display_title %>.<% end %>
<% content_for :eyebrow do %><%= @approved ? t('mailers.approval_decision.decided.eyebrow_approved') : t('mailers.approval_decision.decided.eyebrow_changes') %><% end %>

<h1 style="margin:0 0 16px;font-family:'Sora','Inter',Helvetica,Arial,sans-serif;font-size:22px;font-weight:800;letter-spacing:-0.02em;color:#18122B;">
  <%= @approved ? t('mailers.approval_decision.decided.heading_approved') : t('mailers.approval_decision.decided.heading_changes') %>
</h1>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#564F6F;">
  <strong><%= @client&.name.presence || t('mailers.approval_decision.decided.default_client') %></strong>
  <%= @approved ? t('mailers.approval_decision.decided.verb_approved') : t('mailers.approval_decision.decided.verb_changes') %>
  <strong><%= @ticket.display_title %></strong>
  (<%= @project.name %>)<%= @creative ? t('mailers.approval_decision.decided.piece_suffix', type: @creative.creative_type) : "" %>.
</p>

<% if !@approved && @feedback.present? %>
  <p style="margin:0 0 8px;font-size:13px;font-weight:700;color:#8B86A3;"><%= t('mailers.approval_decision.decided.feedback_label') %></p>
  <blockquote style="margin:0 0 16px;padding:12px 16px;border-left:3px solid #F59E0B;background:#FFF8ED;border-radius:8px;font-size:15px;line-height:1.6;color:#564F6F;">
    <%= @feedback %>
  </blockquote>
<% end %>

<%= email_button(@approved ? t('mailers.approval_decision.decided.button_approved') : t('mailers.approval_decision.decided.button_changes'), @url) %>

<p style="margin:16px 0 0;font-size:13px;line-height:1.5;color:#8B86A3;">
  <%= @approved ? t('mailers.approval_decision.decided.note_approved') : t('mailers.approval_decision.decided.note_changes') %>
</p>
